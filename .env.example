# PFMS environment contract — copy to .env and fill in. NEVER commit .env.
# See CLAUDE.md → "Environment variables" for details.

# --- Database (Supabase Postgres) ---
# Pooled connection (pgbouncer, port 6543) used by the app
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) used by Prisma migrations
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Auth (NextAuth v5) ---
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- AI: Google Gemini (legacy assistant + statement parsing) ---
# Code accepts either name; prefer GEMINI_API_KEY.
GEMINI_API_KEY=""
# GOOGLE_GEMINI_API_KEY=""   # legacy alias, still honored

# --- AI: OpenRouter (50:30:20 statement import) ---
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_VISION_MODEL="openai/gpt-4o"

# --- File storage: Vercel Blob ---
BLOB_READ_WRITE_TOKEN=""

# --- Async extraction worker + cron (extract-sweep, recurring billing) ---
EXTRACT_WORKER_SECRET=""
CRON_SECRET=""

# --- Encryption for sensitive fields (PAN/Aadhaar/account numbers) ---
ENCRYPTION_KEY=""

# --- Supabase client / REST (public) ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
