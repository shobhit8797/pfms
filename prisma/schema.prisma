// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Credentials provider
  accounts      Account[]
  sessions      Session[]
  
  // App specific relations
  bankAccounts         BankAccount[]
  investments          Investment[]
  incomes              Income[]
  expenses             Expense[]
  subscriptions        Subscription[]
  subscriptionPayments SubscriptionPayment[]
  budgets              Budget[]
  creditCards          CreditCard[]
  debitCards           DebitCard[]
  taxDeductions        TaxDeduction[]
  taxProfile           TaxProfile?
  // Phase 2+ Bank Account relations
  transferTransactions TransferTransaction[]
  statementUploads     StatementUpload[]
  reconciliationRecords ReconciliationRecord[]
  balanceAlerts        BalanceAlert[]
  accountGroups        AccountGroup[]

  // 50:30:20 Budgeting tracker relations
  budgetProfiles       BudgetProfile[]
  categories           Category[]
  paymentModes         PaymentMode[]
  transactions         Transaction[]
  receipts             Receipt[]
  statementImports     StatementImport[]
  stagedTransactions   StagedTransaction[]
  apiTokens            ApiToken[]
  upiHandles           UpiHandle[]
  inboundMessages      InboundMessage[]
  merchantPreferences  MerchantPreference[]
  gmailConnection      GmailConnection?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models

enum AccountType {
  SAVINGS
  CURRENT
  SALARY
  OVERDRAFT
}

enum FileType {
  CSV
  XLSX
  PDF
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ReconciliationStatus {
  IN_PROGRESS
  COMPLETED
  DISCREPANCY_FOUND
  RESOLVED
}

enum TransferStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum AlertType {
  LOW_BALANCE
  MINIMUM_BALANCE
  UNUSUAL_ACTIVITY
  HIGH_SPENDING
}

model BankAccount {
  id             String      @id @default(cuid())
  userId         String
  accountName    String
  bankName       String
  accountType    AccountType
  accountNumber  String      // Encrypted in app logic
  ifscCode       String
  currentBalance Decimal     @default(0)
  isPrimary      Boolean     @default(false)
  isActive       Boolean     @default(true)

  // Phase 2: Analytics & Tracking
  minimumBalance Decimal?    @default(0)
  interestRate   Decimal?    // Annual interest rate percentage
  lastReconciled DateTime?   // Last reconciliation date

  // Phase 6: Organization
  groupId        String?
  tags           String[]    // Array of custom tags
  notes          String?     @db.Text
  color          String?     // UI color for visual identification

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group            AccountGroup?           @relation(fields: [groupId], references: [id])
  incomes          Income[]
  expenses         Expense[]
  transfersFrom    TransferTransaction[]   @relation("FromAccount")
  transfersTo      TransferTransaction[]   @relation("ToAccount")
  debitCards       DebitCard[]
  statementUploads StatementUpload[]
  reconciliations  ReconciliationRecord[]
  balanceHistory   BalanceSnapshot[]
  alerts           BalanceAlert[]
}

// Phase 3: Inter-Account Transfers
model TransferTransaction {
  id              String         @id @default(cuid())
  userId          String
  fromAccountId   String
  toAccountId     String
  amount          Decimal
  transferDate    DateTime
  description     String?
  notes           String?        @db.Text
  status          TransferStatus @default(COMPLETED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount BankAccount @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount   BankAccount @relation("ToAccount", fields: [toAccountId], references: [id])
}

// Phase 2: Statement Upload & Reconciliation
model StatementUpload {
  id                 String           @id @default(cuid())
  userId             String
  bankAccountId      String
  fileName           String
  fileType           FileType
  fileSize           Int              // In bytes
  uploadDate         DateTime         @default(now())
  statementPeriod    String           // e.g., "2024-01" for Jan 2024
  statementStartDate DateTime
  statementEndDate   DateTime
  totalTransactions  Int              @default(0)
  matchedCount       Int              @default(0)
  unmatchedCount     Int              @default(0)
  processingStatus   ProcessingStatus @default(PENDING)
  errorMessage       String?          @db.Text

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount    BankAccount            @relation(fields: [bankAccountId], references: [id])
  transactions   ExtractedTransaction[]
  reconciliation ReconciliationRecord?
}

// Extracted transactions from bank statements (raw data)
model ExtractedTransaction {
  id                String   @id @default(cuid())
  statementUploadId String
  transactionDate   DateTime
  description       String
  amount            Decimal
  type              String   // DEBIT, CREDIT
  balance           Decimal? // Running balance if available
  referenceNumber   String?
  category          String?  // Auto-suggested category

  // Reconciliation
  isMatched        Boolean @default(false)
  matchedExpenseId String?
  matchedIncomeId  String?

  statementUpload StatementUpload @relation(fields: [statementUploadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// Reconciliation tracking
model ReconciliationRecord {
  id                String               @id @default(cuid())
  userId            String
  bankAccountId     String
  statementUploadId String               @unique
  reconciliationDate DateTime            @default(now())

  openingBalance  Decimal
  closingBalance  Decimal
  expectedBalance Decimal // From our records
  actualBalance   Decimal // From statement
  difference      Decimal // Discrepancy

  totalCredits   Decimal
  totalDebits    Decimal
  matchedCount   Int
  unmatchedCount Int

  status ReconciliationStatus @default(IN_PROGRESS)
  notes  String?              @db.Text

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount     @relation(fields: [bankAccountId], references: [id])
  statementUpload StatementUpload @relation(fields: [statementUploadId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 2: Balance tracking over time
model BalanceSnapshot {
  id            String   @id @default(cuid())
  bankAccountId String
  balance       Decimal
  snapshotDate  DateTime
  source        String   // MANUAL, RECONCILIATION, TRANSACTION

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
}

// Phase 2: Balance alerts
model BalanceAlert {
  id            String    @id @default(cuid())
  userId        String
  bankAccountId String
  alertType     AlertType
  threshold     Decimal?
  message       String
  isRead        Boolean   @default(false)
  triggeredAt   DateTime  @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

// Phase 6: Account Groups/Folders
model AccountGroup {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String?
  icon        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts BankAccount[]
}

enum AssetClass {
  EQUITY
  DEBT
  HYBRID
  FD
  PPF
  NPS
  GOLD
  REAL_ESTATE
  EPF
  BONDS
  OTHERS
}

model Investment {
  id            String     @id @default(cuid())
  userId        String
  assetClass    AssetClass
  assetName     String
  quantity      Decimal
  purchasePrice Decimal
  purchaseDate  DateTime
  currentPrice  Decimal?
  currentValue  Decimal?
  maturityDate  DateTime?
  notes         String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxDeductions TaxDeduction[]
}

enum IncomeType {
  SALARY
  FREELANCE
  RENTAL
  INTEREST
  BONUS
  GIFT
  OTHER
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Income {
  id            String     @id @default(cuid())
  userId        String
  source        String
  amount        Decimal
  incomeDate    DateTime
  type          IncomeType
  isRecurring   Boolean    @default(false)
  frequency     Frequency?
  isTaxable     Boolean    @default(true)
  bankAccountId String?
  category      String
  invoiceUrl    String?
  receiptUrl    String?    // Vercel Blob URL of an attached invoice/pay-slip (image/PDF)
  receiptName   String?    // original file name of the attached receipt
  notes         String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  inboundMessages InboundMessage[]
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  UPI
  OTHER
}

model Expense {
  id                String        @id @default(cuid())
  userId            String
  amount            Decimal
  expenseDate       DateTime
  category          String
  subcategory       String?
  description       String
  paymentMethod     PaymentMethod
  bankAccountId     String?
  creditCardId      String?
  debitCardId       String?
  isRecurring       Boolean       @default(false)
  frequency         Frequency?
  invoiceUrl        String?
  receiptUrl        String?       // Vercel Blob URL of an attached receipt (image/PDF)
  receiptName       String?       // original file name of the attached receipt
  isBusinessExpense Boolean       @default(false)
  isTaxDeductible   Boolean       @default(false)
  taxSection        String?       // e.g. "80C", "80D"
  notes             String?       @db.Text
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount?   @relation(fields: [bankAccountId], references: [id])
  creditCard    CreditCard?    @relation(fields: [creditCardId], references: [id])
  debitCard     DebitCard?     @relation(fields: [debitCardId], references: [id])
  splits        ExpenseSplit[]
  taxDeductions TaxDeduction[]
  inboundMessages InboundMessage[]
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String
  personName String
  amount     Decimal
  isPaid     Boolean  @default(false)
  paidDate   DateTime?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String
  serviceName     String
  amount          Decimal
  billingCycle    Frequency
  startDate       DateTime
  endDate         DateTime?
  nextBillingDate DateTime
  autoRenewal     Boolean   @default(true)
  reminderDays    Int[]     // Stored as array of integers
  category        String
  paymentMethod   String
  creditCardId    String?
  isActive        Boolean   @default(true)
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard CreditCard? @relation(fields: [creditCardId], references: [id])
  payments   SubscriptionPayment[]
}

/// One row per billing period that was paid (manually or auto-posted by the
/// recurring cron). Drives the subscription payment history and the
/// active/paid month grid. `@@unique([subscriptionId, periodStart])` makes
/// mark-paid idempotent across cron re-runs and manual taps.
model SubscriptionPayment {
  id             String                    @id @default(cuid())
  subscriptionId String
  userId         String
  periodStart    DateTime  // start of the billing period this payment covers
  dueDate        DateTime
  amount         Decimal
  status         SubscriptionPaymentStatus @default(PAID)
  paidDate       DateTime?
  expenseId      String?   // links to the auto-posted / created Expense, if any
  notes          String?   @db.Text
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, periodStart])
  @@index([userId])
}

enum SubscriptionPaymentStatus {
  PAID
  SKIPPED
}

enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  YEARLY
}

model Budget {
  id             String       @id @default(cuid())
  userId         String
  category       String
  amount         Decimal
  period         BudgetPeriod
  startDate      DateTime
  endDate        DateTime
  alertThreshold Int          @default(80) // Percentage
  carryForward   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DebitCard {
  id             String   @id @default(cuid())
  userId         String
  cardName       String
  bankName       String
  lastFourDigits String
  cardNetwork    String?  // VISA, Mastercard, RuPay, Maestro
  bankAccountId  String?
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id])
  expenses    Expense[]

  @@index([userId, isActive])
}

model CreditCard {
  id                 String   @id @default(cuid())
  userId             String
  cardName           String
  bankName           String
  lastFourDigits     String
  creditLimit        Decimal
  currentOutstanding Decimal  @default(0)
  availableCredit    Decimal
  billingDate        Int // Day of month
  dueDate            Int // Day of month
  interestRate       Decimal?
  rewardPoints       Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  subscriptions Subscription[]
}

enum TaxRegime {
  OLD
  NEW
}

model TaxProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  financialYear   String // e.g., "2024-25"
  preferredRegime TaxRegime @default(NEW)
  annualIncome    Decimal   @default(0)
  panNumber       String? // Encrypted
  aadhaarNumber   String? // Encrypted
  employerTDS     Decimal   @default(0)
  advanceTaxPaid  Decimal   @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaxDeduction {
  id            String   @id @default(cuid())
  userId        String
  financialYear String // e.g., "2024-25"
  section       String // 80C, 80D, etc.
  amount        Decimal
  description   String?
  expenseId     String?
  investmentId  String?
  proofUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense    Expense?    @relation(fields: [expenseId], references: [id])
  investment Investment? @relation(fields: [investmentId], references: [id])
}

// ===========================================================================
// 50:30:20 Budgeting Tracker (PRD v1) — parallel surface to the models above.
// All entities are userId-scoped; soft-deletable ones carry deletedAt for the
// delta-sync layer consumed by the future iOS client.
// ===========================================================================

enum CategoryType {
  NEED
  WANT
  SAVING
}

enum TxnSource {
  MANUAL
  RECEIPT_OCR
  STATEMENT_IMPORT
}

enum OcrStatus {
  NONE
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum ImportFileType {
  PDF
  CSV
  IMAGE
}

enum ImportStatus {
  UPLOADED
  EXTRACTING
  NEEDS_REVIEW
  PARTIALLY_APPROVED
  COMPLETED
  FAILED
}

enum TxnDirection {
  DEBIT
  CREDIT
}

enum ReviewStatus {
  PENDING
  EDITED
  APPROVED
  REJECTED
}

// Replaces the spreadsheet `Setup` salary table. One active profile per user;
// superseded profiles are kept (isActive = false) for history.
model BudgetProfile {
  id              String   @id @default(cuid())
  userId          String
  monthlyIncome   Decimal
  needsPct        Decimal  @default(0.5)
  wantsPct        Decimal  @default(0.3)
  savingsPct      Decimal  @default(0.2)
  weeklyLimit     Decimal  @default(10000)
  annualGrowthPct Decimal  @default(0.1)
  effectiveYear   Int
  isActive        Boolean  @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([userId, effectiveYear])
  @@index([userId, updatedAt])
}

model Category {
  id         String       @id @default(cuid())
  userId     String
  name       String
  type       CategoryType
  colorHex   String       @default("#64748b")
  icon       String       @default("Tag")
  isArchived Boolean      @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, isArchived])
  @@index([userId, updatedAt])
}

model PaymentMode {
  id         String   @id @default(cuid())
  userId     String
  name       String
  isArchived Boolean  @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId, isArchived])
  @@index([userId, updatedAt])
}

// The ledger row (spreadsheet `Daily Expense Tracker`).
model Transaction {
  id            String       @id @default(cuid())
  userId        String
  date          DateTime
  description   String
  categoryId    String
  amount        Decimal
  paymentModeId String?
  type          CategoryType // denormalized from category at write time; overridable
  notes         String?      @db.Text
  source        TxnSource    @default(MANUAL)
  importBatchId String? // links rows committed from one StatementImport
  receiptIds    String[]     @default([]) // convenience denorm; Receipt.transactionId is source of truth

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category         @relation(fields: [categoryId], references: [id])
  paymentMode PaymentMode?     @relation(fields: [paymentModeId], references: [id])
  import      StatementImport? @relation(fields: [importBatchId], references: [id])
  receipts    Receipt[]

  @@index([userId, date])
  @@index([userId, type, date])
  @@index([userId, updatedAt])
  @@index([importBatchId])
}

model Receipt {
  id            String    @id @default(cuid())
  userId        String
  transactionId String?
  fileUrl       String
  thumbnailUrl  String?
  ocrStatus     OcrStatus @default(NONE)
  extracted     Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([userId, updatedAt])
  @@index([transactionId])
}

// A bank-statement upload and its extraction job.
model StatementImport {
  id           String         @id @default(cuid())
  userId       String
  fileUrl      String
  fileName     String?
  fileType     ImportFileType
  status       ImportStatus   @default(UPLOADED)
  modelUsed    String?
  tokensUsed   Int?
  costEstimate Decimal?
  errorMessage String?        @db.Text
  completedAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  stagedTxns    StagedTransaction[]
  committedTxns Transaction[]

  @@index([userId, status])
  @@index([userId, updatedAt])
}

// Extracted rows awaiting review — never enter the ledger until approved.
model StagedTransaction {
  id                     String        @id @default(cuid())
  userId                 String
  importBatchId          String
  rawDate                DateTime?
  rawDescription         String
  rawAmount              Decimal
  direction              TxnDirection
  suggestedCategoryId    String?
  suggestedPaymentModeId String?
  suggestedType          CategoryType?
  confidence             Decimal? // 0..1
  isDuplicateGuess       Boolean       @default(false)
  duplicateOfTxnId       String?
  reviewStatus           ReviewStatus  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  import StatementImport @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId, reviewStatus])
  @@index([userId, updatedAt])
}

// Saved UPI payment handles for quick selection in expense forms.
model UpiHandle {
  id        String   @id @default(cuid())
  userId    String
  name      String   // display name, e.g. "GPay", "PhonePe"
  handle    String   // UPI VPA, e.g. "user@ybl"
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
}

// ---------------------------------------------------------------------------
// Message capture — turn bank/UPI transaction SMS into reviewed expenses.
// Source-agnostic: an iOS Shortcut automation, an Android SMS reader, a share
// sheet, or a manual paste all POST raw message text to the same ingest path.
// ---------------------------------------------------------------------------

// Where a captured message came from.
enum MessageSource {
  IOS_SHORTCUT // iOS Shortcuts "Message" automation → POST /api/v1/messages
  ANDROID_SMS //  Android READ_SMS auto-reader (future)
  SHARE //         iOS share sheet / paste from Messages
  MANUAL //        typed/pasted in-app
  EMAIL //         a transaction email (forwarded / pasted / attached .eml)
}

// Lifecycle of a captured message in the review queue.
enum InboundMessageStatus {
  PENDING_REVIEW // parsed as a transaction, awaiting the user's swipe
  DONE //           user saved an expense/income from it
  DISMISSED //      user swiped it away without saving (still won't reappear)
  IGNORED //        not a transaction (OTP, promo, balance enquiry) — auto-hidden
  FAILED //         parsing errored; kept for debugging, hidden from the queue
  DUPLICATE //      same transaction already captured via another source (SMS↔email) — suppressed
}

// A raw message captured from a device, parsed into a candidate transaction.
// `metadata` retains the full original message info as requested.
model InboundMessage {
  id        String        @id @default(cuid())
  userId    String
  source    MessageSource @default(IOS_SHORTCUT)
  rawText   String        @db.Text
  sender    String? //      bank/UPI sender id, e.g. "VM-HDFCBK"
  receivedAt DateTime     @default(now()) // when the SMS arrived on the device

  // Dedupe identical captures (shortcut double-fires, re-paste). sha256 of
  // userId + normalized text + receivedAt-day. Unique so re-ingest is a no-op.
  dedupeHash String       @unique

  status     InboundMessageStatus @default(PENDING_REVIEW)

  // Parsed candidate fields (nullable — the user reviews/edits before saving).
  parsedAmount        Decimal?
  parsedMerchant      String?
  parsedDate          DateTime?
  parsedPaymentMethod PaymentMethod?
  parsedDirection     TxnDirection?
  parsedAccountHint   String? //        masked tail, e.g. "XX1234"
  confidence          Decimal? //       0..1 model confidence
  parseError          String?        @db.Text

  // Category to pre-fill the review card: learned merchant preference if known,
  // else the model's guess. The user can override it (which updates the pref).
  suggestedCategory String?

  // Whether to prompt for a receipt — seeded from the merchant preference at
  // ingest, so the queue card already knows to hide the prompt for opt-outs.
  askReceipt Boolean @default(true)

  // Cross-source dedupe: a stable fingerprint of the *transaction* (amount +
  // merchant + direction), independent of the raw text. An SMS and an email for
  // the same payment share this, so the second capture is marked DUPLICATE and
  // never produces a second expense. `duplicateOfId` points at the canonical row.
  txnFingerprint String?
  duplicateOfId  String?

  // The expense/income created from this message (if the user saved it).
  expenseId String?
  incomeId  String?

  metadata Json? // full message info: original sender, model used, tokens, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expense Expense? @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  income  Income?  @relation(fields: [incomeId], references: [id], onDelete: SetNull)

  @@index([userId, status, receivedAt])
  @@index([userId, txnFingerprint])
}

// Per-merchant learned behavior. Drives auto-classification (category /
// payment method) and the "stop asking for a receipt" preference.
model MerchantPreference {
  id          String  @id @default(cuid())
  userId      String
  merchantKey String //                normalized merchant name (lowercased)
  displayName String //                last-seen human-readable merchant name

  category      String? //             learned spend category to auto-apply
  paymentMethod PaymentMethod? //      learned payment method
  askReceipt    Boolean        @default(true) // false once the user declines

  timesSeen    Int      @default(0)
  declineCount Int      @default(0)
  lastSeenAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantKey])
  @@index([userId])
}

// A user's connected Google account, authorizing the backend to read their
// Gmail for transaction emails. OAuth tokens are encrypted at rest (lib/crypto).
// One connection per user. A background cron sweep (gmail-sweep) polls each.
enum GmailConnectionStatus {
  CONNECTED // tokens valid; syncing
  REVOKED //  user/Google revoked access; needs reconnect
  ERROR //    repeated sync/refresh failure; needs attention
}

model GmailConnection {
  id              String                @id @default(cuid())
  userId          String                @unique
  email           String //              the connected Gmail address
  accessTokenEnc  String                @db.Text
  refreshTokenEnc String                @db.Text
  expiresAt       DateTime //            access-token expiry
  syncQuery       String? //             Gmail search query (overrides the env default)
  lastSyncedAt    DateTime? //           watermark; only fetch mail after this
  status          GmailConnectionStatus @default(CONNECTED)
  lastError       String?               @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastSyncedAt])
}

// Long-lived bearer tokens for native (iOS) clients hitting the REST API.
model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  name       String?
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
